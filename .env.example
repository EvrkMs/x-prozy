# x-prozy — переменные окружения
# Скопируйте этот файл: cp .env.example .env

# ── Кластер ──────────────────────────────────────────
# Общий токен для авторизации нод (обязательно сменить!)
CLUSTER_TOKEN=changeme

# ── Нода ─────────────────────────────────────────────
# Имя ноды (если не задано — используется hostname контейнера)
NODE_NAME=dev-node

# SHA256 отпечаток CA-сертификата панели (hex, 64 символа).
# Получить: docker compose logs panel | grep ca_fingerprint
# Если пусто — нода подключается БЕЗ TLS (небезопасно).
CA_FINGERPRINT=
